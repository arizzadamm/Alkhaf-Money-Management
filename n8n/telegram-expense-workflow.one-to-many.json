        "googlePalmApi": {
          "id": "X8mAJa2T43DFtyRq",
          "name": "Google Gemini(PaLM) Api account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const aiResponse = $input.first().json.output;\nconst rawMessage = String($('Telegram Trigger').item.json.message.text || '').trim();\n\nif (!aiResponse) {\n  return {\n    ok: false,\n    message: 'Bot belum bisa membaca transaksi Anda. Coba tulis seperti: makan siang 25000 dari Bank Jago kategori Needs.',\n    raw_text: rawMessage\n  };\n}\n\nconst cleanText = String(aiResponse)\n  .replace(/```json/gi, '')\n  .replace(/```/g, '')\n  .trim();\n\ntry {\n  const parsedData = JSON.parse(cleanText);\n  const normalized = {\n    name: String(parsedData.name || '').trim(),\n    amount: Number(parsedData.amount || 0),\n    account: String(parsedData.account || '').trim(),\n    category: String(parsedData.category || '').trim(),\n    is_paid: true,\n    date: new Date().toLocaleDateString('en-US', {\n      month: 'short',\n      day: 'numeric',\n      year: 'numeric'\n    })\n  };\n\n  const validCategories = ['Needs', 'Wants', 'Savings'];\n  const hasRequiredFields = Boolean(normalized.name) && normalized.amount > 0 && Boolean(normalized.account) && validCategories.includes(normalized.category);\n\n  if (!hasRequiredFields) {\n    return {\n      ok: false,\n      message: 'Format transaksi belum lengkap. Contoh: makan siang 25000 dari Bank Jago kategori Needs.',\n      parsed_preview: normalized,\n      raw_text: rawMessage\n    };\n  }\n\n  return {\n    ok: true,\n    ...normalized,\n    budget_month: new Date().toISOString().slice(0, 7)\n  };\n} catch (error) {\n  return {\n    ok: false,\n    message: 'Format transaksi belum bisa dipahami. Coba kirim dengan nominal, akun, dan kategori yang jelas.',\n    original_text: aiResponse,\n    details: error.message,\n    raw_text: rawMessage\n  };\n}\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
