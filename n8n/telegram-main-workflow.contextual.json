    {
      "parameters": {
        "jsCode": "const aiResponse = $input.first().json.output;\nconst parserContext = $('Build Parser Payload').item.json;\n\nif (!aiResponse) {\n  return {\n    ok: false,\n    message: 'Bot belum bisa membaca transaksi Anda. Coba tulis seperti: makan siang 25000 pakai BCA Demo kategori Needs.'\n  };\n}\n\nconst cleanText = String(aiResponse)\n  .replace(/```json/gi, '')\n  .replace(/```/g, '')\n  .trim();\n\ntry {\n  const parsed = JSON.parse(cleanText);\n  const accounts = parserContext.accounts || [];\n  const categories = parserContext.categories || [];\n  const accountName = String(parsed.account?.name || parsed.account || '').trim();\n  const categoryName = String(parsed.category?.name || parsed.category || '').trim();\n  const account = accounts.find((item) => item.name === accountName);\n  const category = categories.find((item) => item.name === categoryName);\n  const confidence = Number(parsed.confidence || 0);\n  const needsClarification = Boolean(parsed.needs_clarification);\n  const isTransaction = parsed.is_transaction !== false;\n  const normalized = {\n    name: String(parsed.name || '').trim(),\n    amount: Number(parsed.amount || 0),\n    account: account?.name || '',\n    category: category?.name || '',\n    is_paid: parsed.is_paid !== false,\n    date: String(parsed.date || new Date().toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })),\n    budget_month: String(parsed.budget_month || parserContext.user?.budget_month || new Date().toISOString().slice(0, 7)),\n    notes: String(parsed.notes || ''),\n    confidence\n  };\n\n  const valid = isTransaction && !needsClarification && normalized.name && normalized.amount > 0 && normalized.account && normalized.category && confidence >= 0.75;\n\n  if (!valid) {\n    return {\n      ok: false,\n      message: normalized.account || normalized.category\n        ? 'Saya masih butuh sedikit klarifikasi. Tulis transaksi dengan item, nominal, kantong, dan kategori yang jelas. Contoh: kopi 18000 pakai Cash Demo kategori Wants.'\n        : 'Saya belum yakin transaksi ini masuk ke kantong atau kategori mana. Coba sebutkan kantong dan kategorinya langsung.',\n      parsed_preview: normalized,\n      original_text: cleanText\n    };\n  }\n\n  return {\n    ok: true,\n    ...normalized\n  };\n} catch (error) {\n  return {\n    ok: false,\n    message: 'Format transaksi belum bisa dipahami. Coba kirim dengan nominal, kantong, dan kategori yang jelas.',\n    details: error.message,\n    original_text: cleanText\n  };\n}\n"
      },
