    {
      "parameters": {
        "jsCode": "const payload = $input.first().json;\nconst data = payload.data || null;\n\nif (!data?.user?.id) {\n  return {\n    ok: false,\n    message: payload.error || 'Chat Telegram ini belum terhubung ke akun AlkaFlow.'\n  };\n}\n\nconst accountAliases = (name) => {\n  const lower = String(name || '').trim().toLowerCase();\n  const compact = lower.replace(/\\s+/g, ' ');\n  return Array.from(new Set([lower, compact].filter(Boolean)));\n};\n\nconst accounts = (data.settings?.accounts || []).map((item) => ({\n  id: item.id,\n  name: item.name,\n  aliases: accountAliases(item.name)\n}));\n\nconst categories = (data.settings?.categories || []).map((item) => ({\n  id: item.id,\n  name: item.name,\n  aliases: accountAliases(item.name)\n}));\n\ncategories.push(\n  { id: 'cat-system-income', name: 'Income', aliases: ['income', 'gaji', 'pemasukan'] },\n  { id: 'cat-system-transfer', name: 'Transfer', aliases: ['transfer', 'pindah saldo'] }\n);\n\nreturn {\n  ok: true,\n  message: $('Normalize Message').item.json.raw_text,\n  user: data.user,\n  connection: data.connection,\n  settings: data.settings,\n  accounts,\n  categories\n};\n"
      },
